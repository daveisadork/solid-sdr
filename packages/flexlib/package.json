{
  "name": "@repo/flexlib",
  "version": "0.0.0",
  "description": "FlexRadio protocol and client utilities used by SolidSDR.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/daveisadork/solid-sdr#readme",
  "bugs": {
    "url": "https://github.com/daveisadork/solid-sdr/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daveisadork/solid-sdr.git"
  },
  "author": "Dave Hayes <dwhayes@gmail.com>",
  "files": [
    "dist",
    "README.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "import": "./dist/node.js",
      "require": "./dist/node.cjs"
    },
    "./bridge": {
      "types": "./dist/bridge.d.ts",
      "import": "./dist/bridge.js",
      "require": "./dist/bridge.cjs"
    },
    "./flex": {
      "types": "./dist/flex.d.ts",
      "import": "./dist/flex.js",
      "require": "./dist/flex.cjs"
    },
    "./vita": {
      "types": "./dist/vita.d.ts",
      "import": "./dist/vita.js",
      "require": "./dist/vita.cjs"
    },
    "./util": {
      "types": "./dist/util.d.ts",
      "import": "./dist/util.js",
      "require": "./dist/util.cjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsdown",
    "test": "vitest run",
    "test:watch": "vitest",
    "check-types": "tsc --noEmit",
    "lint": "biome check src tests",
    "lint:fix": "biome check --write src tests"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^24.7.2",
    "bumpp": "^12.0.0",
    "tsdown": "0.22.8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  }
}
