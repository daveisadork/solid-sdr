{
  "name": "@repo/server",
  "private": true,
  "description": "solid-sdr-server (Go) - HTTP/WS/WebRTC server",
  "author": "Dave Hayes <dwhayes@gmail.com>",
  "scripts": {
    "dev": "air -c ./.air.toml",
    "dev:server": "pnpm -s run dev",
    "build": "pnpm -s run build:clean && go build -o dist/bridge ./cmd/bridge",
    "build:prod": "pnpm -s run build:clean && go build -ldflags='-s -w' -o dist/bridge ./cmd/bridge",
    "build:clean": "rimraf dist",
    "test": "go test ./...",
    "lint": "golangci-lint run",
    "clean": "pnpm -s run build:clean && go clean"
  },
  "packageManager": "pnpm@10.18.3",
  "devDependencies": {
    "rimraf": "^5.0.10"
  }
}
